# DeciFlow AI — Environment Configuration
# Copy this to .env and fill in all values before running.

# =============================================================================
# Application
# =============================================================================
PROJECT_NAME="DeciFlow AI"
VERSION="1.0.0"
ENVIRONMENT="development"     # development | staging | production
DEBUG=false

# =============================================================================
# SECURITY — REQUIRED
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(64))"
# In staging/production this MUST differ from the default or startup will fail.
# =============================================================================
SECRET_KEY="REPLACE_ME_with_a_64_char_random_hex_string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# CORS
# =============================================================================
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# =============================================================================
# GCP / Vertex AI (fill these for AI layer)
# =============================================================================
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
VERTEX_AI_MODEL="gemini-pro"

# =============================================================================
# Data Layer
# =============================================================================
BIGQUERY_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="deciflow-data-lake"
